# ==================== 操作系统 ====================

.DS_Store

# ==================== 编辑器 ====================

.agents/
.cursor/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ==================== 依赖包 ====================

node_modules/

# ==================== 日志文件 ====================

logs/
*.log
npm-debug.log*
.pnpm-debug.log*

# ==================== 环境变量配置文件 ====================

**/.env

# ==================== 构建产物 ====================

# -------------------- TypeScript --------------------

*.tsbuildinfo

# -------------------- 其他 --------------------

build/
dist/
out/
output/
target/
