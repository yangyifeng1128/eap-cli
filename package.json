{
  "name": "eap-cli",
  "version": "1.0.0",
  "description": "YYF's personal efficiency augmentation CLI",
  "type": "module",
  "bin": {
    "eap-cli": "./dist/bin/index.js"
  },
  "scripts": {
    "dev": "node --import tsx src/bin/index.ts",
    "build": "esbuild src/bin/index.ts --bundle --platform=node --format=esm --outfile=dist/bin/index.js --packages=external",
    "start": "node dist/bin/index.js",
    "ts:check": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "clean": "pnpx rimraf node_modules dist pnpm-lock.yaml"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "esbuild": "^0.27.5",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.33.0"
  },
  "packageManager": "pnpm@10.33.0"
}
